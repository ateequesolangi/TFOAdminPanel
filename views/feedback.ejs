function setupFilterUI() {
  const filterButton = document.getElementById('filterButton');
  const sortButton = document.getElementById('sortButton');
  const filterPanel = document.getElementById('filterPanel');
  const sortPanel = document.getElementById('sortPanel');
  const clearAllFilters = document.getElementById('clearAllFilters');
  const filterControls = document.querySelectorAll('.filter-control');
  const sortOptions = document.querySelectorAll('.sort-option');
  const sortOptionInput = document.getElementById('sortOption');
  
  filterButton.addEventListener('click', function() {
    if (filterPanel.style.display === 'none') {
      sortPanel.style.display = 'none';
      filterPanel.style.display = 'block';
    } else {
      filterPanel.style.display = 'none';
    }
  });
  
  sortButton.addEventListener('click', function() {
    if (sortPanel.style.display === 'none') {
      filterPanel.style.display = 'none';
      sortPanel.style.display = 'block';
    } else {
      sortPanel.style.display = 'none';
    }
  });
  
  document.addEventListener('click', function(event) {
    if (!event.target.closest('#filterButton') && 
        !event.target.closest('#sortButton') && 
        !event.target.closest('#filterPanel') && 
        !event.target.closest('#sortPanel')) {
      filterPanel.style.display = 'none';
      sortPanel.style.display = 'none';
    }
  });
  
  clearAllFilters.addEventListener('click', function() {
    filterControls.forEach(control => {
      control.value = 'All';
    });
    updateFilterCount();
    applyFilters();
  });
  
  filterControls.forEach(control => {
    control.addEventListener('change', function() {
      updateFilterCount();
      applyFilters();
    });
  });
  
  sortOptions.forEach(option => {
    option.addEventListener('click', function() {
      const sortValue = this.dataset.sort;
      sortOptionInput.value = sortValue;
      document.querySelectorAll('.sort-check').forEach(check => {
        check.style.display = 'none';
      });
      this.querySelector('.sort-check').style.display = 'block';
      sortPanel.style.display = 'none';
      applyFilters();
    });
  });
  
  const defaultSortOption = 'date_desc';
  sortOptionInput.value = defaultSortOption;
  document.querySelectorAll('.sort-check').forEach(check => {
    check.style.display = 'none';
  });
  document.querySelector(`.sort-option[data-sort="${defaultSortOption}"] .sort-check`).style.display = 'block';
  updateFilterCount();
}

function updateFilterCount() {
  let activeFilterCount = 0;
  const filterControls = document.querySelectorAll('.filter-control');
  
  filterControls.forEach(control => {
    if (control.value !== 'All') {
      activeFilterCount++;
    }
  });
  
  const filterCountBadges = document.querySelectorAll('.filter-count');
  filterCountBadges.forEach(badge => {
    badge.textContent = activeFilterCount;
  });
  
  const clearAllButton = document.getElementById('clearAllFilters');
  clearAllButton.style.display = activeFilterCount > 0 ? 'block' : 'none';
}

function fetchDataAndRender() {
  showLoadingSpinner();
  fetch('/feedback/chart-data')
    .then(response => response.json())
    .then(data => {
      hideLoadingSpinner();
      if (data.success) {
        const sortOption = document.getElementById('sortOption').value;
        let sortedQuestions = data.questions;
        
        if (sortOption === 'date_desc') {
          sortedQuestions.sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
        } else if (sortOption === 'date_asc') {
          sortedQuestions.sort((a, b) => new Date(a.created_at) - new Date(b.created_at));
        } else if (sortOption === 'votes_desc') {
          sortedQuestions.sort((a, b) => (b.totalResponses || 0) - (a.totalResponses || 0));
        } else if (sortOption === 'votes_asc') {
          sortedQuestions.sort((a, b) => (a.totalResponses || 0) - (b.totalResponses || 0));
        }
        
        renderFeedbackCharts(sortedQuestions);
      } else {
        console.error('Failed to fetch chart data.');
      }
    })
    .catch(error => {
      hideLoadingSpinner();
      console.error('Error fetching chart data:', error);
    });
}

function renderFeedbackCharts(questions) {
  const activeContainer = document.getElementById('activeFeedbackCharts');
  const inactiveContainer = document.getElementById('inactiveFeedbackCharts');
  activeContainer.innerHTML = '';
  inactiveContainer.innerHTML = '';
  let chartIndex = 0;

  questions.forEach(question => {
    const colDiv = document.createElement('div');
    colDiv.className = 'col-12 col-md-4 col-lg-3 mb-4 position-relative';

    const cardDiv = document.createElement('div');
    cardDiv.className = 'card glass-card h-100';

    const cardBodyDiv = document.createElement('div');
    cardBodyDiv.className = 'card-body d-flex flex-column';

    const title = document.createElement('h5');
    title.className = 'card-title';
    title.textContent = question.question_text;

    const topRightDiv = document.createElement('div');
    topRightDiv.className = 'top-right-info';

    const totalResponsesDiv = document.createElement('div');
    totalResponsesDiv.className = 'total-responses';
    totalResponsesDiv.innerHTML = `<i class="fa fa-users"></i> ${question.totalResponses}`;

    const averageRatingDiv = document.createElement('div');
    averageRatingDiv.className = 'average-rating';
    averageRatingDiv.innerHTML = `<i class="fa fa-star"></i> ${question.averageRating}`;

    topRightDiv.appendChild(totalResponsesDiv);
    if (question.question_type === 'rating') {
      topRightDiv.appendChild(averageRatingDiv);
    }

    const chartContainer = document.createElement('div');
    chartContainer.className = 'chart-container flex-grow-1 mt-3';
    chartContainer.style.position = 'relative';
    chartContainer.style.minHeight = '250px';

    const canvas = document.createElement('canvas');
    canvas.id = `chart-${chartIndex++}`;
    chartContainer.appendChild(canvas);

    const versionNameDiv = document.createElement('div');
    versionNameDiv.className = 'version-name';
    versionNameDiv.textContent = `V: ${question.version_name || 'N/A'}`;
    topRightDiv.appendChild(versionNameDiv);

    const deleteButton = document.createElement('i');
    deleteButton.className = 'fa fa-times delete-icon';
    deleteButton.addEventListener('click', () => confirmDeleteQuestion(question.question_id));

    cardBodyDiv.appendChild(title);
    cardBodyDiv.appendChild(chartContainer);
    cardDiv.appendChild(topRightDiv);
    cardDiv.appendChild(cardBodyDiv);
    cardDiv.appendChild(deleteButton);
    colDiv.appendChild(cardDiv);

    const editButton = document.createElement('i');
    editButton.className = 'fa fa-pencil edit-icon';
    editButton.style.display = 'none';
    editButton.addEventListener('click', (e) => {
      e.stopPropagation();
      openEditModal(question);
    });
    cardDiv.appendChild(editButton);
    cardDiv.addEventListener('mouseenter', () => {
      editButton.style.display = 'block';
    });
    cardDiv.addEventListener('mouseleave', () => {
      editButton.style.display = 'none';
    });

    const ctx = canvas.getContext('2d');
    let chartConfig = {};

    if (question.question_type === 'yesno') {
      chartConfig = {
        type: 'pie',
        data: {
          labels: ['Yes', 'No'],
          datasets: [{
            data: [question.aggregatedResponses.Yes, question.aggregatedResponses.No],
            backgroundColor: ['#10B981', '#EF4444']
          }]
        },
        options: { plugins: { valueDisplay: true }, maintainAspectRatio: false, responsive: true },
        plugins: [valueDisplayPlugin]
      };
    } else if (question.question_type === 'rating') {
      const labels = question.aggregatedResponses.map(item => `${item.star} Star`);
      const data = question.aggregatedResponses.map(item => item.count);
      chartConfig = {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            data: data,
            backgroundColor: '#F59E0B'
          }]
        },
        options: {
          plugins: { valueDisplay: true },
          scales: { y: { beginAtZero: true } },
          maintainAspectRatio: false,
          responsive: true
        },
        plugins: [valueDisplayPlugin]
      };
    } else if (question.question_type === 'emoji') {
      chartConfig = {
        type: 'pie',
        data: {
          labels: ['Like', 'Heart', 'Wow', 'Sad', 'Angry'],
          datasets: [{
            data: [question.aggregatedResponses.Like, question.aggregatedResponses.Heart, question.aggregatedResponses.Wow, question.aggregatedResponses.Sad, question.aggregatedResponses.Angry],
            backgroundColor: ['#10B981', '#F472B6', '#F59E0B', '#3B82F6', '#EF4444']
          }]
        },
        options: { plugins: { valueDisplay: true }, maintainAspectRatio: false, responsive: true },
        plugins: [valueDisplayPlugin]
      };
    }

    new Chart(ctx, chartConfig);

    if (question.is_active == 1) {
      activeContainer.appendChild(colDiv);
    } else {
      inactiveContainer.appendChild(colDiv);
    }
  });
}

function openEditModal(question) {
  const modal = new bootstrap.Modal(document.getElementById('editQuestionModal'));
  document.getElementById('editQuestionId').value = question.question_id;
  document.getElementById('editQuestionText').value = question.question_text;
  document.getElementById('editQuestionType').value = question.question_type;
  document.getElementById('editIsActive').value = question.is_active;
  document.getElementById('editMode').value = question.mode;
  document.getElementById('editDifficulty').value = question.difficulty;
  document.getElementById('editStadium').value = question.stadium;
  modal.show();
}

function handleEditFormSubmit(e) {
  e.preventDefault();
  const formData = new FormData(this);
  const updatedQuestion = Object.fromEntries(formData.entries());
  fetch('/feedback/updateQuestion', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(updatedQuestion),
  })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        showToast('Feedback question updated successfully.');
        bootstrap.Modal.getInstance(document.getElementById('editQuestionModal')).hide();
        fetchDataAndRender();
      } else {
        showToast('Failed to update feedback question. Please try again.', 'danger');
      }
    })
    .catch(error => {
      console.error('Error updating feedback question:', error);
      showToast('An error occurred while updating the feedback question.', 'danger');
    });
}

function applyFilters() {
  showLoadingSpinner();
  const mode = document.getElementById('filterMode').value;
  const difficulty = document.getElementById('filterDifficulty').value;
  const stadium = document.getElementById('filterStadium').value;
  const version = document.getElementById('filterVersion').value;
  const sortOption = document.getElementById('sortOption').value;

  fetch('/feedback/chart-data')
    .then(response => response.json())
    .then(data => {
      hideLoadingSpinner();
      if (data.success) {
        let filteredQuestions = data.questions;

        if (mode !== 'All') {
          filteredQuestions = filteredQuestions.filter(question => question.mode === mode);
        }
        if (difficulty !== 'All') {
          filteredQuestions = filteredQuestions.filter(question => question.difficulty === difficulty);
        }
        if (stadium !== 'All') {
          filteredQuestions = filteredQuestions.filter(question => question.stadium === stadium);
        }
        if (version !== 'All') {
          filteredQuestions = filteredQuestions.filter(question => question.version_name === version);
        }

        if (sortOption === 'date_desc') {
          filteredQuestions.sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
        } else if (sortOption === 'date_asc') {
          filteredQuestions.sort((a, b) => new Date(a.created_at) - new Date(b.created_at));
        } else if (sortOption === 'votes_desc') {
          filteredQuestions.sort((a, b) => (b.totalResponses || 0) - (a.totalResponses || 0));
        } else if (sortOption === 'votes_asc') {
          filteredQuestions.sort((a, b) => (a.totalResponses || 0) - (b.totalResponses || 0));
        }

        renderFeedbackCharts(filteredQuestions);
      } else {
        console.error('Failed to fetch chart data.');
      }
    })
    .catch(error => {
      hideLoadingSpinner();
      console.error('Error fetching chart data:', error);
    });
}

function populateVersionFilter() {
  fetch('/feedback/versions')
    .then(response => response.json())
    .then(data => {
      console.log("Fetched versions:", data.versions);
      const filterVersion = document.getElementById('filterVersion');
      filterVersion.innerHTML = '<option value="All" selected>All</option>';
      data.versions.forEach(version => {
        const option = document.createElement('option');
        option.value = version;
        option.textContent = version;
        filterVersion.appendChild(option);
      });
    })
    .catch(error => console.error('Error fetching versions:', error));
}

function confirmDeleteQuestion(questionId) {
  if (confirm('Are you sure you want to delete this feedback question and all its responses?')) {
    fetch(`/feedback/delete/${questionId}`, { method: 'DELETE' })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          showToast('Feedback question has been deleted successfully.');
          fetchDataAndRender();
        } else {
          showToast('Failed to delete the feedback question. Please try again.', 'danger');
        }
      })
      .catch(error => {
        console.error('Error deleting feedback question:', error);
        showToast('An error occurred while deleting the feedback question.', 'danger');
      });
  }
}

function deleteAllFeedback() {
  if (confirm('Are you sure you want to delete all feedback questions and their responses?')) {
    fetch('/feedback/delete-all', { method: 'DELETE' })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          showToast('All feedback questions and their responses have been deleted.');
          fetchDataAndRender();
        } else {
          showToast('Failed to delete all feedback questions. Please try again.', 'danger');
        }
      })
      .catch(error => {
        console.error('Error deleting all feedback questions:', error);
        showToast('An error occurred while deleting all feedback questions.', 'danger');
      });
  }
}

function showLoadingSpinner() {
  const container = document.getElementById('feedbackCharts');
  if (!document.getElementById('spinner')) {
    const spinner = document.createElement('div');
    spinner.id = 'spinner';
    spinner.className = 'd-flex justify-content-center';
    spinner.innerHTML = '<div class="spinner-border text-primary" role="status"><span class="sr-only">Loading...</span></div>';
    container.appendChild(spinner);
  }
}

function hideLoadingSpinner() {
  const spinner = document.getElementById('spinner');
  if (spinner) spinner.remove();
}

function showToast(message, type = 'success') {
  const toastContainer = document.getElementById('toastContainer');
  
  if (!toastContainer) {
    const container = document.createElement('div');
    container.id = 'toastContainer';
    container.className = 'toast-container position-fixed bottom-0 end-0 p-3';
    document.body.appendChild(container);
  }
  
  const toast = document.createElement('div');
  toast.className = `toast align-items-center text-white bg-${type} border-0`;
  toast.setAttribute('role', 'alert');
  toast.setAttribute('aria-live', 'assertive');
  toast.setAttribute('aria-atomic', 'true');
  
  toast.innerHTML = `
    <div class="d-flex">
      <div class="toast-body">${message}</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
  `;
  
  document.getElementById('toastContainer').appendChild(toast);
  
  const bsToast = new bootstrap.Toast(toast, { autohide: true, delay: 3000 });
  bsToast.show();
  
  toast.addEventListener('hidden.bs.toast', function() { toast.remove(); });
}

const valueDisplayPlugin = {
  id: 'valueDisplay',
  afterDatasetsDraw: function(chart) {
    const ctx = chart.ctx;
    chart.data.datasets.forEach(function(dataset, i) {
      const meta = chart.getDatasetMeta(i);
      if (!meta.hidden) {
        const total = dataset.data.reduce((sum, val) => sum + val, 0);
        meta.data.forEach(function(element, index) {
          if (dataset.data[index] == 0) return;
          
          ctx.fillStyle = 'rgb(200, 200, 200)';
          const fontSize = 12;
          const fontStyle = 'normal';
          const fontFamily = 'Inter, Helvetica Neue';
          ctx.font = Chart.helpers.fontString(fontSize, fontStyle, fontFamily);
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          const padding = 5;
          const position = element.tooltipPosition();

          let dataString = dataset.data[index].toString();
          if (
            chart.config.type === 'pie' &&
            chart.data.labels.length === 2 &&
            chart.data.labels[0] === 'Yes' &&
            chart.data.labels[1] === 'No' &&
            total > 0
          ) {
            const percentage = Math.round((dataset.data[index] / total) * 100);
            dataString += " (" + percentage + "%)";
          }
          ctx.fillText(dataString, position.x, position.y - (fontSize / 2) - padding);
        });
      }
    });
  }
};

function initBootstrapComponents() {
  const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
  tooltipTriggerList.map(function(tooltipTriggerEl) {
    return new bootstrap.Tooltip(tooltipTriggerEl);
  });
  
  const popoverTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="popover"]'));
  popoverTriggerList.map(function(popoverTriggerEl) {
    return new bootstrap.Popover(popoverTriggerEl);
  });
}

document.addEventListener('DOMContentLoaded', function() {
  initBootstrapComponents();
});
     </script>
