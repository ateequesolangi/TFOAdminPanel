<%- include('partials/head') %>

<body>

    <div class="main-wrapper">
        <%- include('partials/sidebar') %>

        <div class="content-area">
            <%- include('partials/header') %>

            <div class="container-fluid pt-4">
                <div class="row align-items-center mb-4 animate-fade">
                    <div class="col">
                        <p class="page-label mb-1">Administrative Features</p>
                        <h2 class="fw-bold mb-0">Review <span class="text-gradient">Bat Unlock</span></h2>
                    </div>
                </div>

                <div class="row g-4 animate-fade">
                    <!-- Add Reviewer Card -->
                    <div class="col-12 col-xl-4">
                        <div class="glass-card p-4 h-100">
                            <h5 class="fw-bold mb-4">Add Reviewer</h5>
                            <p class="small text-muted mb-4">Manually mark a user as having reviewed the game to unlock their special bat.</p>
                            
                            <form id="addReviewerForm">
                                <div class="mb-3">
                                    <label for="username" class="form-label small fw-bold">Username</label>
                                    <input type="text" class="form-control" id="username" name="username" placeholder="Enter username..." required>
                                </div>
                                <button type="submit" class="btn btn-primary w-100 py-2 d-flex align-items-center justify-content-center gap-2">
                                    <ion-icon name="unlock-outline" style="font-size: 1.2rem;"></ion-icon>
                                    <span>Unlock Review Bat</span>
                                </button>
                            </form>
                            
                            <div id="alertContainer" class="mt-4"></div>
                        </div>
                    </div>

                    <!-- Reviewers List Card -->
                    <div class="col-12 col-xl-8">
                        <div class="glass-card p-4 h-100">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h5 class="fw-bold mb-0">Reviewers List</h5>
                                <span class="badge bg-primary rounded-pill px-3 py-2 small"><%= users.length %> Users Total</span>
                            </div>
                            
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>User ID</th>
                                            <th>Username</th>
                                            <th>Total GP</th>
                                            <th class="text-center">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (users && users.length > 0) { %>
                                            <% users.forEach((user, index) => { %>
                                                <tr>
                                                    <td><span class="text-muted"><%= index + 1 %></span></td>
                                                    <td><code>#<%= user.user_id %></code></td>
                                                    <td class="fw-bold">@<%= user.user_name %></td>
                                                    <td><%= user.total_accumulated_gp.toLocaleString() %> GP</td>
                                                    <td class="text-center">
                                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill d-inline-flex align-items-center gap-1">
                                                            <ion-icon name="checkmark-circle"></ion-icon>
                                                            Reviewed
                                                        </span>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="5" class="text-center py-5 text-muted">
                                                    <ion-icon name="information-circle-outline" style="font-size: 2rem;"></ion-icon>
                                                    <p class="mb-0 mt-2">No users found who have reviewed the game yet.</p>
                                                </td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <%- include('partials/footer') %>
        </div>

        <a href="javaScript:;" class="back-to-top">
            <ion-icon name="arrow-up-outline"></ion-icon>
        </a>

        <div class="overlay nav-toggle-icon"></div>
    </div>

    <!-- JS Files-->
    <script src="assets/js/jquery.min.js"></script>
    <script src="assets/plugins/simplebar/js/simplebar.min.js"></script>
    <script src="assets/plugins/metismenu/js/metisMenu.min.js"></script>
    <script src="assets/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
    <script src="assets/plugins/perfect-scrollbar/js/perfect-scrollbar.js"></script>
    <script src="assets/js/main.js"></script>

    <script>
        $(document).ready(function() {
            $('#addReviewerForm').on('submit', function(e) {
                e.preventDefault();
                
                const username = $('#username').val().trim();
                const $btn = $(this).find('button');
                const $input = $('#username');
                
                if (!username) return;
                
                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Processing...');
                $input.prop('disabled', true);
                
                $.ajax({
                    url: '/review-bat-unlock/add',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ username: username }),
                    success: function(response) {
                        if (response.success) {
                            showAlert('success', response.message);
                            $input.val('');
                            // Reload after short delay to show the new reviewer in the list
                            setTimeout(() => {
                                window.location.reload();
                            }, 1500);
                        } else {
                            showAlert('danger', response.message);
                        }
                    },
                    error: function(xhr) {
                        const message = xhr.responseJSON ? xhr.responseJSON.message : 'An error occurred. Please try again.';
                        showAlert('danger', message);
                    },
                    complete: function() {
                        $btn.prop('disabled', false).html('<ion-icon name="unlock-outline" style="font-size: 1.2rem;"></ion-icon><span>Unlock Review Bat</span>');
                        $input.prop('disabled', false);
                    }
                });
            });

            function showAlert(type, message) {
                const icon = type === 'success' ? 'checkmark-circle-outline' : 'alert-circle-outline';
                const alertHtml = `
                    <div class="alert alert-${type} alert-dismissible fade show d-flex align-items-center gap-2 mb-0" role="alert">
                        <ion-icon name="${icon}" style="font-size: 1.2rem;"></ion-icon>
                        <div class="small fw-bold">${message}</div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>`;
                $('#alertContainer').html(alertHtml);
            }
        });
    </script>

</body>
</html>
