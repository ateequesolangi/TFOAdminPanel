<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>TFO Admin | Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link href="assets/css/main.css" rel="stylesheet">
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

        body::before {
            background: 
                radial-gradient(ellipse 600px 400px at 30% 20%, rgba(99, 102, 241, 0.1) 0%, transparent 100%),
                radial-gradient(ellipse 500px 350px at 70% 80%, rgba(6, 214, 160, 0.06) 0%, transparent 100%);
        }

        .login-container {
            width: 100%;
            max-width: 420px;
            padding: 20px;
        }

        .login-card {
            padding: 2.5rem;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .login-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: conic-gradient(transparent, var(--primary), transparent 30%);
            animation: rotate 4s linear infinite;
            z-index: -1;
            opacity: 0.2;
        }

        .login-header img {
            width: 72px;
            margin-bottom: 1.25rem;
            filter: drop-shadow(0 0 15px var(--primary-glow));
        }

        .login-header h2 {
            margin-bottom: 0.25rem;
        }

        .btn-login {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            color: white;
            padding: 12px;
            border-radius: var(--radius-md);
            font-weight: 700;
            width: 100%;
            margin-top: 0.75rem;
            transition: var(--transition);
            box-shadow: 0 4px 15px rgba(79, 70, 229, 0.3);
            font-size: 0.9rem;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(79, 70, 229, 0.4);
            filter: brightness(1.1);
        }

        .error-message {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #FCA5A5;
            padding: 10px;
            border-radius: var(--radius-sm);
            margin-bottom: 1.25rem;
            font-size: 0.85rem;
        }

        .dev-badge {
            background: rgba(6, 214, 160, 0.08);
            border: 1px solid rgba(6, 214, 160, 0.15);
            color: var(--secondary);
            padding: 8px;
            border-radius: var(--radius-sm);
            font-size: 0.75rem;
            margin-bottom: 1.25rem;
        }
    </style>
</head>
<body>
    <div class="login-container animate-fade">
        <div class="login-card glass-card">
            <div class="login-header">
                <img src="https://finalovers.cricket/wp-content/themes/finaloverscricket/assets/img/tfo_logo.png" alt="TFO Logo">
                <h2 class="text-gradient">Welcome Back</h2>
                <p class="text-muted small mb-0">Sign in to access TFO Admin Panel</p>
            </div>

            <form action="/auth" method="post" class="mt-4 text-start">
                <div class="mb-3">
                    <label class="form-label ms-1">Username</label>
                    <input type="text" class="form-control" name="username" placeholder="Enter username" required autofocus value="<%= typeof rememberedUsername !== 'undefined' ? rememberedUsername : '' %>">
                </div>

                <div class="mb-3">
                    <label class="form-label ms-1">Password</label>
                    <input type="password" class="form-control" name="password" placeholder="••••••••" required id="password" value="<%= typeof rememberedPassword !== 'undefined' ? rememberedPassword : '' %>">
                </div>

                <% if (isDevelopment) { %>
                    <div class="dev-badge text-center">
                        <i class="fa-solid fa-code-branch me-2"></i> reCAPTCHA bypassed (Dev Mode)
                    </div>
                <% } else { %>
                    <div class="g-recaptcha mb-3 d-flex justify-content-center" data-sitekey="<%= recaptchaSiteKey %>" data-theme="dark"></div>
                <% } %>

                <% if (typeof errorMessage !== 'undefined' && errorMessage !== '') { %>
                    <div class="error-message text-center">
                        <i class="fa-solid fa-circle-exclamation me-2"></i> <%= errorMessage %>
                    </div>
                <% } %>

                <div class="d-flex justify-content-between align-items-center mb-3 px-1">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="remember-me" id="rememberMe" <%= typeof rememberedUsername !== 'undefined' ? 'checked' : '' %>>
                        <label class="form-check-label" for="rememberMe">Remember me</label>
                    </div>
                    <a href="javascript:;" class="small fw-medium" style="color: var(--primary-light); text-decoration: none;">Forgot?</a>
                </div>

                <button type="submit" class="btn-login">Sign In</button>
            </form>
        </div>
        <p class="text-center mt-4 small" style="color: var(--text-faint);">© 2026 TFO Cricket. All rights reserved.</p>
    </div>

    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
</body>
</html>
